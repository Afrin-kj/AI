import matplotlib.pyplot as plt
import numpy as np

overs = np.arange(1, 21)  # Creates array [1, 2, ..., 20]
scores = [4, 5, 6, 7, 8, 9, 4, 2, 3, 7, 8, 1, 9, 4, 12, 7, 8, 13, 15, 6]

plt.bar(overs, scores, color="green")
plt.title("India's scores over 20 overs (Bar chart)")
plt.xlabel("Over number")
plt.ylabel("Runs scored")
plt.xticks(overs)
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.show()
